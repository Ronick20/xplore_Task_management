{
  "info": {
    "_postman_id": "task-management-collection",
    "name": "Task Management API",
    "description": "Complete API collection for Admin & Employee Task Management System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Admin",
      "item": [
        {
          "name": "Admin Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/admin/login",
              "host": ["{{base_url}}"],
              "path": ["admin", "login"]
            }
          }
        },
        {
          "name": "Get All Employees",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/employees",
              "host": ["{{base_url}}"],
              "path": ["admin", "employees"]
            }
          }
        },
        {
          "name": "Approve Employee",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/employees/:employeeId/approve",
              "host": ["{{base_url}}"],
              "path": ["admin", "employees", ":employeeId", "approve"]
            }
          }
        },
        {
          "name": "Reject Employee",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/employees/:employeeId/reject",
              "host": ["{{base_url}}"],
              "path": ["admin", "employees", ":employeeId", "reject"]
            }
          }
        },
        {
          "name": "Assign Task",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Task Title\",\n  \"description\": \"Task description\",\n  \"assignedTo\": \"EMPLOYEE_ID\",\n  \"dueDate\": \"2024-05-31\",\n  \"priority\": \"High\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/admin/tasks/assign",
              "host": ["{{base_url}}"],
              "path": ["admin", "tasks", "assign"]
            }
          }
        },
        {
          "name": "Get All Tasks",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/tasks",
              "host": ["{{base_url}}"],
              "path": ["admin", "tasks"]
            }
          }
        },
        {
          "name": "Delete Task",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/tasks/:taskId",
              "host": ["{{base_url}}"],
              "path": ["admin", "tasks", ":taskId"]
            }
          }
        }
      ]
    },
    {
      "name": "Employee",
      "item": [
        {
          "name": "Employee Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Employee Name\",\n  \"email\": \"employee@example.com\",\n  \"password\": \"password123\",\n  \"phone\": \"1234567890\",\n  \"department\": \"IT\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/employee/register",
              "host": ["{{base_url}}"],
              "path": ["employee", "register"]
            }
          }
        },
        {
          "name": "Employee Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"employee@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/employee/login",
              "host": ["{{base_url}}"],
              "path": ["employee", "login"]
            }
          }
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/employee/profile",
              "host": ["{{base_url}}"],
              "path": ["employee", "profile"]
            }
          }
        },
        {
          "name": "Get Employee Tasks",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/employee/tasks",
              "host": ["{{base_url}}"],
              "path": ["employee", "tasks"]
            }
          }
        },
        {
          "name": "Update Task Status",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"In Progress\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/employee/tasks/:taskId/status",
              "host": ["{{base_url}}"],
              "path": ["employee", "tasks", ":taskId", "status"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000/api"
    },
    {
      "key": "token",
      "value": ""
    }
  ]
}
